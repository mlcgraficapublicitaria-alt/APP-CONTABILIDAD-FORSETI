generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ADVISOR
  VIEWER
}

enum TaxCaseStatus {
  DRAFT
  IN_REVIEW
  READY
  CLOSED
}

enum DataConfidence {
  CONFIRMED
  ESTIMATED
  PENDING
}

enum DocumentStatus {
  PENDING
  RECEIVED
  REVIEWED
  REJECTED
}

enum ValidationSeverity {
  INFO
  WARNING
  ERROR
}

enum ValidationStatus {
  OPEN
  RESOLVED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  role         UserRole     @default(ADVISOR)
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  taxCases     TaxCase[]
  documents    Document[]   @relation("DocumentUploader")
  auditEvents  AuditEvent[]
  invoices     Invoice[]    @relation("InvoiceCreatedBy")
}

model TaxCase {
  id           String            @id @default(cuid())
  reference    String            @unique
  title        String
  taxpayerName String
  taxpayerNif  String?
  fiscalYear   Int
  status       TaxCaseStatus     @default(DRAFT)
  ownerId      String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  owner        User              @relation(fields: [ownerId], references: [id])
  taxProfile   TaxProfile?
  documents    Document[]
  dataPoints   DataPoint[]
  issues       ValidationIssue[]
  summary      CaseSummary?
  auditEvents  AuditEvent[]
}

model TaxProfile {
  id                 String         @id @default(cuid())
  taxCaseId          String         @unique
  residencyStatus    String         @default("pending")
  employmentIncome   Boolean        @default(false)
  rentalIncome       Boolean        @default(false)
  investmentIncome   Boolean        @default(false)
  selfEmployment     Boolean        @default(false)
  notes              String?
  confidence         DataConfidence @default(PENDING)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  taxCase            TaxCase        @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)
}

model DocumentRequirement {
  id          String     @id @default(cuid())
  code        String     @unique
  label       String
  description String
  required    Boolean    @default(true)
  active      Boolean    @default(true)
  sortOrder   Int        @default(0)
  documents   Document[]
}

model Document {
  id            String              @id @default(cuid())
  taxCaseId     String
  requirementId String?
  fileName      String
  mimeType      String
  sizeBytes     Int
  storageKey    String
  status        DocumentStatus      @default(RECEIVED)
  notes         String?
  uploadedById  String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  taxCase       TaxCase             @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)
  requirement   DocumentRequirement? @relation(fields: [requirementId], references: [id])
  uploadedBy    User                @relation("DocumentUploader", fields: [uploadedById], references: [id])
}

model DataPoint {
  id          String         @id @default(cuid())
  taxCaseId   String
  key         String
  label       String
  value       String?
  source      String?
  confidence  DataConfidence @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  taxCase     TaxCase        @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)

  @@unique([taxCaseId, key])
}

model ValidationIssue {
  id          String             @id @default(cuid())
  taxCaseId   String
  code        String
  title       String
  description String
  severity    ValidationSeverity @default(WARNING)
  status      ValidationStatus   @default(OPEN)
  createdAt   DateTime           @default(now())
  resolvedAt  DateTime?
  taxCase     TaxCase            @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)
}

model CaseSummary {
  id               String         @id @default(cuid())
  taxCaseId        String         @unique
  status           DataConfidence @default(PENDING)
  preliminaryNotes String
  missingCount     Int            @default(0)
  issueCount       Int            @default(0)
  confirmedCount   Int            @default(0)
  estimatedCount   Int            @default(0)
  updatedAt        DateTime       @updatedAt
  taxCase          TaxCase        @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id         String   @id @default(cuid())
  taxCaseId  String?
  userId     String?
  action     String
  entity     String
  entityId   String?
  metadata   String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  taxCase    TaxCase? @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])
}

model InvoiceIssuerProfile {
  id             String    @id @default(cuid())
  code           String    @unique
  legalName      String
  taxId          String?
  addressLine1   String?
  addressLine2   String?
  postalCode     String?
  city           String?
  province       String?
  country        String?
  email          String?
  phone          String?
  website        String?
  bankAccount    String?
  invoicePrefix  String?
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  invoices       Invoice[]
}

model InvoiceClient {
  id             String    @id @default(cuid())
  code           String?   @unique
  legalName      String
  taxId          String?
  addressLine1   String?
  addressLine2   String?
  postalCode     String?
  city           String?
  province       String?
  country        String?
  email          String?
  phone          String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  invoices       Invoice[]
}

model InvoiceTemplate {
  id             String    @id @default(cuid())
  code           String    @unique
  name           String
  description    String?
  layoutKey      String
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  invoices       Invoice[]
}

model Invoice {
  id                  String              @id @default(cuid())
  issuerProfileId     String
  clientId            String
  templateId          String?
  createdById         String?
  status              InvoiceStatus       @default(DRAFT)
  documentName        String
  series              String?
  number              Int
  issueDate           DateTime
  articleCode         String?
  serviceDescription  String
  subtotalAmount      Decimal             @db.Decimal(10, 2)
  vatRate             Decimal             @db.Decimal(5, 2)
  vatAmount           Decimal             @db.Decimal(10, 2)
  irpfRate            Decimal             @db.Decimal(5, 2)
  irpfAmount          Decimal             @db.Decimal(10, 2)
  totalAmount         Decimal             @db.Decimal(10, 2)
  notes               String?             @db.Text
  renderedHtml        String?             @db.LongText
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  issuerProfile       InvoiceIssuerProfile @relation(fields: [issuerProfileId], references: [id], onDelete: Restrict)
  client              InvoiceClient       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  template            InvoiceTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy           User?               @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  lines               InvoiceLine[]

  @@unique([series, number])
  @@index([clientId, issueDate])
  @@index([issuerProfileId, issueDate])
}

model InvoiceLine {
  id               String   @id @default(cuid())
  invoiceId        String
  sortOrder        Int      @default(0)
  articleCode      String?
  description      String   @db.Text
  quantity         Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice        Decimal  @db.Decimal(10, 2)
  discountAmount   Decimal  @default(0) @db.Decimal(10, 2)
  lineTotalAmount  Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, sortOrder])
}
