generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ADVISOR
  VIEWER
}

enum TaxCaseStatus {
  DRAFT
  IN_REVIEW
  READY
  CLOSED
}

enum DataConfidence {
  CONFIRMED
  ESTIMATED
  PENDING
}

enum DocumentStatus {
  PENDING
  RECEIVED
  REVIEWED
  REJECTED
}

enum ValidationSeverity {
  INFO
  WARNING
  ERROR
}

enum ValidationStatus {
  OPEN
  RESOLVED
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  role         UserRole     @default(ADVISOR)
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  taxCases     TaxCase[]
  documents    Document[]   @relation("DocumentUploader")
  auditEvents  AuditEvent[]
}

model TaxCase {
  id           String            @id @default(cuid())
  reference    String            @unique
  title        String
  taxpayerName String
  taxpayerNif  String?
  fiscalYear   Int
  status       TaxCaseStatus     @default(DRAFT)
  ownerId      String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  owner        User              @relation(fields: [ownerId], references: [id])
  taxProfile   TaxProfile?
  documents    Document[]
  dataPoints   DataPoint[]
  issues       ValidationIssue[]
  summary      CaseSummary?
  auditEvents  AuditEvent[]
}

model TaxProfile {
  id                 String         @id @default(cuid())
  taxCaseId          String         @unique
  residencyStatus    String         @default("pending")
  employmentIncome   Boolean        @default(false)
  rentalIncome       Boolean        @default(false)
  investmentIncome   Boolean        @default(false)
  selfEmployment     Boolean        @default(false)
  notes              String?
  confidence         DataConfidence @default(PENDING)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  taxCase            TaxCase        @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)
}

model DocumentRequirement {
  id          String     @id @default(cuid())
  code        String     @unique
  label       String
  description String
  required    Boolean    @default(true)
  active      Boolean    @default(true)
  sortOrder   Int        @default(0)
  documents   Document[]
}

model Document {
  id            String              @id @default(cuid())
  taxCaseId     String
  requirementId String?
  fileName      String
  mimeType      String
  sizeBytes     Int
  storageKey    String
  status        DocumentStatus      @default(RECEIVED)
  notes         String?
  uploadedById  String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  taxCase       TaxCase             @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)
  requirement   DocumentRequirement? @relation(fields: [requirementId], references: [id])
  uploadedBy    User                @relation("DocumentUploader", fields: [uploadedById], references: [id])
}

model DataPoint {
  id          String         @id @default(cuid())
  taxCaseId   String
  key         String
  label       String
  value       String?
  source      String?
  confidence  DataConfidence @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  taxCase     TaxCase        @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)

  @@unique([taxCaseId, key])
}

model ValidationIssue {
  id          String             @id @default(cuid())
  taxCaseId   String
  code        String
  title       String
  description String
  severity    ValidationSeverity @default(WARNING)
  status      ValidationStatus   @default(OPEN)
  createdAt   DateTime           @default(now())
  resolvedAt  DateTime?
  taxCase     TaxCase            @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)
}

model CaseSummary {
  id               String         @id @default(cuid())
  taxCaseId        String         @unique
  status           DataConfidence @default(PENDING)
  preliminaryNotes String
  missingCount     Int            @default(0)
  issueCount       Int            @default(0)
  confirmedCount   Int            @default(0)
  estimatedCount   Int            @default(0)
  updatedAt        DateTime       @updatedAt
  taxCase          TaxCase        @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id         String   @id @default(cuid())
  taxCaseId  String?
  userId     String?
  action     String
  entity     String
  entityId   String?
  metadata   String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  taxCase    TaxCase? @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])
}
